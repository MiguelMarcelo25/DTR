# ── Database (Supabase Postgres) ──────────────────────────────
# Pooled connection (PgBouncer, port 6543) for the app runtime
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) used by Prisma Migrate
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_SECRET="replace-with-long-random-string"
JWT_REFRESH_SECRET="replace-with-different-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Supabase Storage ──────────────────────────────────────────
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"
SUPABASE_STORAGE_BUCKET="hrms-files"

# ── Server ────────────────────────────────────────────────────
NODE_ENV="development"
PORT="4000"
CORS_ORIGIN="http://localhost:3000"
# Business timezone for attendance/DTR day boundaries + late computation
APP_TIMEZONE="Asia/Manila"

# ── Auth cookie ───────────────────────────────────────────────
REFRESH_COOKIE_NAME="hrms_rt"
COOKIE_DOMAIN=""

# Google Calendar appointment sync
# Set GOOGLE_CALENDAR_ID to the target shared/HR calendar id.
GOOGLE_CALENDAR_ID=""
GOOGLE_CALENDAR_TIMEZONE="Asia/Manila"
# Service account mode. Share the target calendar with this service account,
# or set GOOGLE_CALENDAR_IMPERSONATE_EMAIL when using Workspace delegation.
GOOGLE_CALENDAR_CLIENT_EMAIL=""
GOOGLE_CALENDAR_PRIVATE_KEY=""
GOOGLE_CALENDAR_IMPERSONATE_EMAIL=""
# OAuth fallback mode. Used only when service account credentials are absent.
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_CALENDAR_REFRESH_TOKEN=""
GOOGLE_CALENDAR_WEBHOOK_TOKEN=""
